<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <ProgressBar
            android:id="@+id/pbPcbDetail"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true"
            android:visibility="gone" />

        <!-- PCB 기본 정보 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:text="🔲 PCB 프로젝트 정보"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#185FA5"
                android:paddingBottom="10dp" />

            <!-- 관리번호 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="관리번호" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbManageNo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C" android:textStyle="bold"/>
            </LinearLayout>

            <!-- 프로젝트명 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="프로젝트명" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbProjectName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/>
            </LinearLayout>

            <!-- 모델명 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="모델명" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbModelName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/>
            </LinearLayout>

            <!-- 회사명 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="회사명" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbCompany" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/>
            </LinearLayout>

            <!-- 담당자 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="담당자" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbDesigner" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/>
            </LinearLayout>

            <!-- 층수 / 두께 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="층수" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbLayers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  /  " android:textColor="#A0AEC0" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbThickness" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C"/>
            </LinearLayout>

            <!-- 연결프로젝트 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="4dp">
                <TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="연결프로젝트" android:textColor="#718096" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPcbLinkedProject" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#2B6CB0"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 이슈(기타) 카드 -->
        <LinearLayout
            android:id="@+id/layoutPcbNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFBEB"
            android:padding="16dp"
            android:elevation="2dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:text="📝 기타 / 이슈"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#B7791F"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvPcbNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#744210"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- 첨부파일 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp">

            <TextView
                android:text="📎 첨부파일 (카테고리별)"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#185FA5"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:id="@+id/llPcbFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvPcbNoFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="첨부된 파일이 없습니다."
                android:textColor="#A0AEC0"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
