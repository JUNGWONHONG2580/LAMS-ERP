<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F7FAFC">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
        <ProgressBar android:id="@+id/pbDetail" android:layout_width="match_parent" android:layout_height="3dp" style="?android:attr/progressBarStyleHorizontal" android:indeterminate="true" android:visibility="gone"/>
        <!-- 기본 정보 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:elevation="2dp" android:layout_marginBottom="10dp">
            <TextView android:text="📋 프로젝트 정보" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#185FA5" android:paddingBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="코드" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailCode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="프로젝트명" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="고객사" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailClient" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="PM" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailPm" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="연락처" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailContact" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="상태" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="세금계산서" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailTax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#2B6CB0" android:textStyle="bold"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="진행률" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailProgress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"><TextView android:layout_width="90dp" android:layout_height="wrap_content" android:text="기간" android:textColor="#718096" android:textSize="13sp"/><TextView android:id="@+id/tvDetailStartDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" ~ " android:textColor="#A0AEC0" android:textSize="13sp"/><TextView android:id="@+id/tvDetailEndDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#1A202C"/></LinearLayout>
        </LinearLayout>
        <!-- 이슈 -->
        <LinearLayout android:id="@+id/layoutIssue" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFBEB" android:padding="16dp" android:elevation="2dp" android:layout_marginBottom="10dp" android:visibility="gone">
            <TextView android:text="⚠️ 이슈사항" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#B7791F" android:paddingBottom="8dp"/>
            <TextView android:id="@+id/tvDetailIssue" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#744210" android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>
        <!-- 첨부파일 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:elevation="2dp" android:layout_marginBottom="10dp">
            <TextView android:text="📎 첨부파일" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#185FA5" android:paddingBottom="10dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvFiles" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
            <TextView android:id="@+id/tvNoFiles" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="첨부된 파일이 없습니다." android:textColor="#A0AEC0" android:textSize="13sp" android:gravity="center" android:padding="16dp" android:visibility="gone"/>
        </LinearLayout>
        <!-- 업로드 버튼 -->
        <Button android:id="@+id/btnUpload" android:layout_width="match_parent" android:layout_height="48dp" android:text="📷 사진·동영상 업로드" android:backgroundTint="#185FA5" android:textColor="#FFFFFF" android:textSize="14sp"/>
    </LinearLayout>
</ScrollView>
